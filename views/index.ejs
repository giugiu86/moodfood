<body>
   <%- include("header.ejs") %>
<!-- Section uvp    -->
  <section id="section_uvp">
      <!-- Uvp -->
      <div id="root" class="row">
          <div class="div_uvp col-lg-6">
            <h1 class="h1_uvp">
               Mangi sano,<br>al tuo passo
            </h1>
            <p class="p_uvp"><strong>MoodFood</strong> è l'app che finalmente ti aiuta a organizzare e preparare ricette facili e gustose in pochi click, rispettando il tuo <em>mood</em></p>
			<a class="btn" href="#section_how_works">Scopri di più</a>
			<a class="btn_testapp" href="https://forms.gle/bpnbRE8GHkrT4qJg6">Testa l'app</a>
          </div>
          <div class="div_img_main col-lg-6">
              <img class="img_main" id="id_img_main" src="img_main_placeholder" alt="Main Image">
              <script>
                 document.addEventListener("DOMContentLoaded", function() {
                   const c_path_img = "<%= path_img %>"+"img_main.webp";
                   var imgElement = document.getElementById("id_img_main");
                   if (imgElement) {
                     imgElement.src = c_path_img;
                   } else {
                   console.error("Element with id 'path_img' not found.");
                 }
               });
             </script>
          </div>
      </div>
    </div>
  </section>
    <div class="div_section_white">
    </div>
<!-- Section how works    -->
    <section id="section_how_works">
      <div class="container-fluid">
        <!-- Introduction -->
        <div class="row main_div_how_it_works">
            <div class="div_h1_description col-lg-6">
              <h1 class="h1_description">
                Un menù semplice da realizzare e stimolante!
              </h1>
            </div>
            <div class="col-lg-6">
              <p class="p_description"><strong>MoodFood</strong> ti ispira con migliaia di ricette gustose e veloci, facilmente programmabili nel tuo menù. Ti restituisce la lista della spesa con le quantità pronte da acquistare: andare al supermercato non sarà più uno stress, ma un vero piacere!</p>
            </div>
        </div>
      <div class="row">
          <div class="col">
            <h1 class="h1_centered">
              Come funziona?
            </h1>
          </div>
          <div>
          <div class="div_how_it_works div_mood">
            <div class="div_icon">
            <div class="icon mood">
              <span style="font-size: 1.5em; color: #2D334B;">
              <i class="fa-solid fa-hand-holding-heart"></i>
              </span>
            </div>
            </div>
            <h2 style="font-size: 120%;">In che <em>mood</em> sei?</h2>
            <p class="p_description_centered">Esprimi come ti senti con i tanti filtri a tua disposizione. Ti svegli con l'influenza? Seleziona le ricette con tipo di Piatto "Zuppe e minestre"<br>Vogliamo prenderci cura di te!<br></p>
          </div>
          <div class="div_how_it_works div_like">
           <div class="div_icon">
            <div class="icon like">
              <span style="font-size: 1.5em; color: #2D334B;">
                <i class="fa-solid fa-utensils"></i>
             </span>
            </div>
           </div>
            <h2>Cosa ti piace?</h2>
            <p class="p_description_centered">Lasciati ispirare dalle tantissime ricette disponibili e salva quelle che ti attraggono di più.<br>Vogliamo appagare il tuo gusto!</p><br><br><br>
          </div>
          <div class="div_how_it_works div_organize">
           <div class="div_icon">
            <div class="icon organize">
              <span style="font-size: 1.5em; color: #2D334B;">
              <i class="fa-solid fa-clipboard-list"></i>
              </span>
            </div>
           </div>
            <h2>Quali pasti vuoi programmare?</h2>
            <p class="p_description_centered">Scegli tu quanti e quali pasti vuoi programmare per il tuo menù.<br>Vogliamo che tu abbia una vita sociale!</p><br><br><br>
          </div>
          <div class="div_how_it_works div_cook">
           <div class="div_icon">
            <div class="icon cook">
              <span style="font-size: 1.5em; color: #2D334B;">
              <i class="fa-solid fa-kitchen-set"></i>
              </span>
            </div>
           </div>
            <h2>Goditi la spesa</h2>
            <p class="p_description_centered">Ottieni la lista della spesa suddivisa per corsie del supermercato.<br>Vogliamo che il momento dell'acquisto sia senza stress e sprechi!</p>
          </div>
        </div>
        </div>
        </div>
    </section>
      <div class="div_section_color">
      </div>
      <!-- Section mission-->
    <section id="section_mission">
            <div class="container-fluid">
              <div class="row">
                  <div class="col">
                    <h1 class="h1_centered">
                      La nostra <em>Mission</em>
                    </h1>
                  </div>
              <div>
              <div class="row">
                  <div class="col-lg-6">
                    <p class="p_description_list"><strong>MoodFood</strong> nasce dalla convinzione che <strong>mangiare sano</strong> sia un <strong>percorso</strong> che coinvolge più aspetti, da costruire <strong>gradualmente nel rispetto dei propri tempi.</strong>
					 Le linee guida per una sana alimentazione consigliano di:
					 <li>Limitare prodotti processati e preconfezionati;</li>
					 <li>Ridurre farine e zuccheri raffinati;</li>
					 <li>Consumare le proteine secondo frequenze adeguate;</li>
					 <li>Preferire ingredienti di stagione;</li>
					 <li>Bilanciare carboidrati, proteine, verdura/frutta e grassi;</li>
					 <li>Variare i metodi di cottura e gli alimenti;</li>
					 <li>Ascoltare il proprio corpo;</li>
					 <li>Dare priorità a ingredienti che supportino eventuali disturbi, carenze nutrizionali o intolleranze;</li>
					 <p class="p_description_list">Sappiamo, per esperienza, che mettere in pratica <strong>tutti questi aspetti</strong> può creare <strong>confusione</strong> e <strong>frustrazione</strong>.
						Per questo la nostra <strong>missione</strong> è guidarti passo dopo passo, trasformando <strong>piccoli graduali cambiamenti</strong> in <strong>abitudini sostenibili</strong> e rispettose del tuo <strong>benessere complessivo</strong>.
					 </p>
					</p>
                  </div>
                  <div class="col-lg-6">
					  <div class="div_icon">
						  <h1 class="h1_padded">
						  Kalipè, l'augurio himalayano, è la nostra filosofia: camminare sempre a passo corto e lento per arrivare all'obiettivo.
						  </h1>
					  </div>
                  </div>
              </div>
    </section>
    <div class="div_section_white">
    </div>
    <!-- Section why-->
  <section id="section_why">
          <div class="container-fluid">
            <div class="row">
                <div class="col">
                  <h1 class="h1_centered">
                    Perché MoodFood?
                  </h1>
                </div>
            <div>
            <div class="row">
                <div class="div_img_why col-lg-4">
                  <img id="id_img_chef" class="img_main" src="img_chef_placeholder" alt="Image Chef">
                  <script>
                     document.addEventListener("DOMContentLoaded", function() {
                       const c_path_img = "<%= path_img %>"+"img_chef.jpeg";
                       var imgElement = document.getElementById("id_img_chef");
                       if (imgElement) {
                         imgElement.src = c_path_img;
                       } else {
                       console.error("Element with id 'path_img' not found.");
                     }
                   });
                 </script>
                </div>
                <div class="div_p_why col-lg-4">
                  <h2 class="h2_left">
                    Come un vero chef</h2>
                  <p class="p_description">Puoi organizzare la preparazione dei tuoi pasti in modo semplice per non avere più fretta davanti ai fornelli e poter esprimere al meglio la tua passione e creatività! Una sera i tuoi amici ti invitano a cena? Nessun problema, con MoodFood è il menù che si adatta a te. </p>
                </div>
                <div class="div_img_why col-lg-4">
                  <img id="id_img_liberta" class="img_main" src="img_liberta_placeholder" alt="Image Libertà">
                  <script>
                     document.addEventListener("DOMContentLoaded", function() {
                       const c_path_img = "<%= path_img %>"+"img_liberta.webp";
                       var imgElement = document.getElementById("id_img_liberta");
                       if (imgElement) {
                         imgElement.src = c_path_img;
                       } else {
                       console.error("Element with id 'path_img' not found.");
                     }
                   });
                 </script>
                </div>
            </div>
            <div class="row">
              <div class="div_p_why col-lg-4">
                <h2 class="h2_left">Ricette nuove e personali</h2>
                <p class="p_description">Finalmente, oltre alle tue ricette personali a cui sei abituata, puoi aggiungere nel tuo menù nuove ricette da provare! Hai in frigo pochi ingredienti? Niente panico! MoodFood ti consiglia tutte le possibili ricette per poter svuotare il tuo frigo e appagare il tuo palato! </p>
              </div>
                  <div class="div_img_why col-lg-4">
                    <img id="id_img_collaborazione" class="img_collaboration" src="images/img_collaborazione.webp" alt="Image Collaborazione">
                    <script>
                       document.addEventListener("DOMContentLoaded", function() {
                         const c_path_img = "<%= path_img %>"+"img_collaborazione.webp";
                         var imgElement = document.getElementById("id_img_collaborazione");
                         if (imgElement) {
                           imgElement.src = c_path_img;
                         } else {
                         console.error("Element with id 'path_img' not found.");
                       }
                     });
                   </script>
                  </div>
              <div class="div_p_why col-lg-4">
                  <h2 class="h2_left">Insieme a te</h2>
                  <p class="p_description">Dietro a MoodFood ci sono Persone pronte a supportarti. Il nostro è un approccio inclusivo, volto al confronto costruttivo per accompagnare più Persone possibili ad approcciarsi con gioia ad una cucina più salutare.</p>
              </div>
            </div>
  </section>
  <div class="div_section_color">
  </div>
  <!-- Section contact-->
<section id="section_contact">
        <div class="container-fluid">
          <div class="row">
              <div class="col">
                <h1 class="h1_centered">
                Vuoi collaborare con noi o vuoi conoscere meglio il mondo MoodFood? Scrivici!
                </h1>
                  <!-- Input form contact-->
                <form  action="/submit" method="POST">
                  <input name="contact_name" type="text" class="text-input" placeholder="Nome" />
                  <input name="contact_email" type="email" class="text-input" placeholder="Email (obbligatoria)" required  oninvalid="this.setCustomValidity('Per favore inserisci un\'email valida')"
                   oninput="setCustomValidity('')")/>
                  <textarea name="contact_text" class="text-input" placeholder="Messaggio" maxlength ="2000"></textarea>
                  <input type="text" id="NONACCEDIBOT" name="NONACCEDIBOT" class="hidden">
                  <input class="submit" type="submit" value="INVIA ✉" />
                </form>
                <br>
                <p><a href="/privacypolicy" target="_blank">Privacy Policy</a></p>
            </div>
        </div>
</section>
